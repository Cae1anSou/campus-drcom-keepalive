# Preferred/backup interfaces
NPM_PREFERRED_INTERFACE=enp7s0
NPM_BACKUP_INTERFACE=wlp0s20f3

# Health checks (comma separated). Leave empty to only check link+IP.
NPM_PROBE_TARGETS=8.8.8.8,1.1.1.1
NPM_PROBE_TIMEOUT=1
NPM_INTERVAL=10

# Route metrics in main table
NPM_PREFERRED_METRIC=100
NPM_BACKUP_METRIC=30000

# Debounce thresholds
NPM_FAIL_THRESHOLD=3
NPM_RECOVER_THRESHOLD=2
